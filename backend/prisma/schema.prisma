generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./habit_hero.db"
}

model User {
  id       Int      @id @default(autoincrement())
  username String   @unique
  password String
  habits   Habit[]
}

model Habit {
  id         Int        @id @default(autoincrement())
  name       String
  category   String
  frequency  String
  start_date String
  user       User       @relation(fields: [user_id], references: [id])
  user_id    Int
  logs       HabitLog[]
}

model HabitLog {
  id        Int      @id @default(autoincrement())
  date      String
  status    String
  note      String?
  sentiment String? 
  habit     Habit    @relation(fields: [habit_id], references: [id], onDelete: Cascade)
  habit_id  Int
}